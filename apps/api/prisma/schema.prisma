generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Student {
  id                Int               @id @default(autoincrement())
  name              String
  email             String            @unique
  password          String

  learningProfiles  LearningProfile[]
}

model LearningProfile {
  id             Int     @id @default(autoincrement())
  subject        String
  mastery        Int
  recommendation String

  studentId      Int
  student         Student @relation(fields: [studentId], references: [id])
}